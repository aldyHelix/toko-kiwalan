{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "type-check": "vue-tsc --noEmit",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "format": "prettier --write \"resources/**/*.{ts,vue,css}\"",
        "format:check": "prettier --check \"resources/**/*.{ts,vue,css}\""
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^25.9.3",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.8.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^10.5.0",
        "eslint-plugin-vue": "^10.9.2",
        "laravel-vite-plugin": "^2.0.0",
        "prettier": "^3.8.4",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "vite": "^7.0.7",
        "vue-tsc": "^3.3.5"
    },
    "dependencies": {
        "@inertiajs/vue3": "^3.4.0",
        "vue": "^3.5.38"
    }
